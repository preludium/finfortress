# Copy this file to .env and fill in your values

# ── LLM ──────────────────────────────────────────────────────────────────────
# Option A: OpenAI API
OPENAI_API_KEY=sk-...

# Option B: oMLX local server (Apple Silicon)
# OPENAI_BASE_URL=http://localhost:8000/v1
# OPENAI_API_KEY=omlx-...

# ── API ───────────────────────────────────────────────────────────────────────
# Comma-separated allowed origins for CORS (defaults to Streamlit local port)
CORS_ORIGINS=http://localhost:8501

# ── Vector store ──────────────────────────────────────────────────────────────
QDRANT_URL=http://localhost:6333
QDRANT_COLLECTION=polish_finance
QDRANT_API_KEY=                        # only needed for Qdrant Cloud

# ── Embeddings ────────────────────────────────────────────────────────────────
# Model runs locally — no API key needed for public models
# Add token only if using a gated HuggingFace model
HUGGINGFACE_TOKEN=
HF_TOKEN=$HUGGINGFACE_TOKEN
HF_HUB_VERBOSITY=warning
# Set to 1 once the embedding model is downloaded — prevents HEAD checks to huggingface.co on every startup
HF_HUB_OFFLINE=1

# ── Observability (optional) ──────────────────────────────────────────────────
# Set LANGCHAIN_TRACING_V2=true and add your API key to enable LangSmith tracing.
# LangGraph traces every node, LLM call, and retrieved chunk automatically — no
# code changes needed. Get your key at https://smith.langchain.com
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=
LANGCHAIN_PROJECT=finfortress

# ── Misc ──────────────────────────────────────────────────────────────────────
TRANSFORMERS_VERBOSITY=error

# ── Ingestion ─────────────────────────────────────────────────────────────────
# Whisper model size: tiny | base | small | medium | large
# base = good speed/accuracy tradeoff for Polish
# medium = better Polish accuracy, significantly slower
WHISPER_MODEL=base

# Delay between HTTP requests during scraping (seconds)
# Be polite to bloggers' servers
SCRAPE_DELAY_SECONDS=1.5

# ── Agent tuning ──────────────────────────────────────────────────────────────
# Model for main generation
# LLM_MODEL=gpt-4o
LLM_MODEL=Qwen2.5-32B-Instruct-4bit

# Model for grading (cheaper/faster than generator)
# GRADER_MODEL=gpt-4o-mini
GRADER_MODEL=Qwen2.5-7B-Instruct-4bit

# Grading threshold — below this, trigger rewrite
GRADE_THRESHOLD=0.6
# Max rewrite attempts before fallback
MAX_REWRITES=2
# Months before a document is considered potentially stale
STALE_MONTHS=18

# Regex pattern for URL segments to skip during blog crawl (tag/category/etc pages)
# Leave empty to disable. Per-source overrides: url_skip_patterns list in blogs.json.
SCRAPER_SKIP_PATTERN=/(tag|tagi|tags|category|kategori|author|autor|page|feed|wp-content|wp-admin|wp-json|search|szukaj|attachment|sitemap)/
